# ─────────────────────────────────────────────────────────────
# VastHost OS — environment configuration
# Copy to .env and fill in. NEVER commit .env (it is git-ignored).
# ─────────────────────────────────────────────────────────────

# Vast — your personal Vast.ai account API key
VAST_API_KEY=

# Observer — initial watched GPU class (more can be added in Settings)
VAST_OBSERVER_DEFAULT_GPU=RTX_4090
VAST_OBSERVER_DEFAULT_NUM_GPUS=1

# App wiring (internal container hostnames)
API_INTERNAL_URL=http://api:8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/vasthost
REDIS_URL=redis://redis:6379/0

# Secret used to encrypt stored Vast API keys at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=

# Dev flags
ALLOW_ALL_CORS=true

# Postgres container bootstrap (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vasthost

# Web — public port the dashboard binds on (LAN reachable)
WEB_PORT=8111

# Optional debug host ports. Only the dashboard (WEB_PORT) needs to be public;
# the API/DB/Redis publishes below are for local debugging. Override any that
# collide with something already running on your host.
API_HOST_PORT=8000
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
