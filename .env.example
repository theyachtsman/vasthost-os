# ─────────────────────────────────────────────────────────────
# GPUIQ — environment configuration
# Copy to .env and fill in. NEVER commit .env (it is git-ignored).
# ─────────────────────────────────────────────────────────────

# Vast — OPTIONAL legacy single-account key. In the two-key model the platform
# key is set in the Admin Console and each user connects their own key in
# Settings. Left here only for backward-compatible local validation.
VAST_API_KEY=

# Observer — initial watched GPU class (auto-discovery maintains the rest)
VAST_OBSERVER_DEFAULT_GPU=RTX_4090
VAST_OBSERVER_DEFAULT_NUM_GPUS=1

# App wiring (internal container hostnames)
API_INTERNAL_URL=http://api:8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/vasthost
REDIS_URL=redis://redis:6379/0

# Secret used to encrypt stored provider API keys (platform + user) at rest.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Admin console seeding (Part 10). On first boot, if no admin exists, an admin
# is created from these. Real values live ONLY in the untracked .env — never
# commit them. Leave blank to skip seeding and create the admin out-of-band.
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=changeme

# Dev flags
ALLOW_ALL_CORS=true

# Postgres container bootstrap (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vasthost

# Web — public port the dashboard binds on (LAN reachable)
WEB_PORT=8111

# Optional debug host ports. Only the dashboard (WEB_PORT) needs to be public;
# the API/DB/Redis publishes below are for local debugging. Override any that
# collide with something already running on your host.
API_HOST_PORT=8000
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
